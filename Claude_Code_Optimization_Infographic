        datasets: [{
            label: '예상 비용 (상대치 %)',
            data: [100, 20],
            backgroundColor: ['#EF4444', '#10B981'],
            borderRadius: 6
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
            y: {
                beginAtZero: true,
