<script>
function wrapLabel(text, maxLen) {
    if(text.length <= maxLen) return text;
    let words = text.split(' ');
    let lines = [];
    let currentLine = '';
    
    for(let i = 0; i < words.length; i++) {
        let word = words[i];
        if ((currentLine + word).length > maxLen) {
            if(currentLine.trim() !== '') {
                lines.push(currentLine.trim());
            }
            currentLine = word + ' ';
        } else {
            currentLine += word + ' ';
        }
    }
    if(currentLine.trim() !== '') {
        lines.push(currentLine.trim());
    }
    return lines;
}

const radarRawLabels = [
    "어텐션 희석 현상 발생 (Attention Drop)",
    "누적된 지시문 명령 충돌 (Command Conflict)",
    "토큰 예산 초과 압박 (Token Pressure)",
    "무관한 히스토리 미스매치 (Relevance Issue)"
];

const radarWrappedLabels = radarRawLabels.map(label => wrapLabel(label, 16));

const ctxRadar = document.getElementById('contextRotChart').getContext('2d');
new Chart(ctxRadar, {
    type: 'radar',
    data: {
        labels: radarWrappedLabels,
        datasets: [{
            label: '초기 상태 (0h)',
            data: [10, 10, 10, 10],
            backgroundColor: 'rgba(6, 182, 212, 0.2)',
            borderColor: '#06B6D4',
            pointBackgroundColor: '#06B6D4',
            borderWidth: 2
        }, {
            label: '작업 2시간 후 (Rot 발생)',
            data: [85, 75, 90, 80],
            backgroundColor: 'rgba(239, 68, 68, 0.3)',
            borderColor: '#EF4444',
            pointBackgroundColor: '#EF4444',
            borderWidth: 2
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
            r: {
                angleLines: { color: '#E2E8F0' },
                grid: { color: '#E2E8F0' },
                pointLabels: {
                    color: '#475569',
                    font: { family: 'Segoe UI', size: 12, weight: 'bold' }
                },
                ticks: { display: false, max: 100, min: 0 }
            }
        },
        plugins: {
            legend: { position: 'bottom', labels: { color: '#334155' } },
            tooltip: {
                callbacks: {
                    title: function(tooltipItems) {
                        const item = tooltipItems[0];
                        let label = item.chart.data.labels[item.dataIndex];
                        if (Array.isArray(label)) {
                            return label.join(' ');
                        } else {
                            return label;
                        }
                    }
                }
            }
        }
    }
});

const barRawLabels = ["비효율적 기본 세팅 (Opus 기반)", "최적화 후 세팅 (Sonnet + Haiku)"];
const barWrappedLabels = barRawLabels.map(label => wrapLabel(label, 16));

const ctxBar = document.getElementById('costComparisonChart').getContext('2d');
new Chart(ctxBar, {
    type: 'bar',
    data: {
